---
import siteContent from "../data/site-content.json";
import SectionTitle from "../components/SectionTitle.astro";

const { instagram, services } = siteContent;
const previewImages = services.slice(0, 3);
---

<section id="instagram" class="bg-ebony py-24">
  <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
    <div data-reveal>
      <SectionTitle
        eyebrow={instagram.eyebrow}
        title={instagram.title}
        description={instagram.description}
        align="center"
      />
    </div>

    <div data-reveal style="--reveal-delay: 120ms;" class="glass-panel mx-auto mt-12 max-w-5xl rounded-3xl border border-white/15 p-6 sm:p-10">
      <script src="https://elfsightcdn.com/platform.js" async></script>
      <div class="elfsight-app-c574bd26-6191-4dd8-8e6c-d5ddcac2136d" data-elfsight-app-lazy></div>
    </div>
  </div>
</section>

