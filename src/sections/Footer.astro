---
import siteContent from "../data/site-content.json";

const { brand, footer } = siteContent;
---

<footer class="border-t border-white/10 bg-[var(--color-ebony)]">
  <div class="mx-auto flex max-w-7xl flex-col gap-6 px-6 py-10 sm:px-8 lg:flex-row lg:items-center lg:justify-between lg:px-12">
    <div>
      <p class="font-[var(--font-header)] text-xl text-white">{brand.name}</p>
      <p class="mt-1 text-xs tracking-[0.15em] uppercase text-[var(--color-gold-luxury)]">{brand.tagline}</p>
      <p class="mt-3 text-sm text-[var(--color-smoke-white)]/70">{footer.legal}</p>
      <p class="text-xs text-[var(--color-smoke-white)]/55">{footer.copyright}</p>
    </div>

    <div class="flex flex-wrap gap-5">
      {
        footer.socials.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noreferrer"
            class="text-xs font-semibold tracking-[0.16em] uppercase text-[var(--color-gold-luxury)] transition hover:text-[var(--color-cyan-electric)]"
          >
            {social.name}
          </a>
        ))
      }
    </div>

    <div class="powered-by">
      <span>Powered by</span>
      <a href="https://rock-byte-tech.com.co" target="_blank" rel="noopener" class="powered-link">
        <img
          class="powered-logo"
          src="https://rock-byte-tech.com.co/_astro/logo-principal-blanco.C207YXwr_Zpvt0R.webp"
          alt="Logo Rock Byte Tech"
          loading="lazy"
        />
      </a>
    </div>
  </div>
</footer>
