---
import siteContent from "../data/site-content.json";
import SectionTitle from "../components/SectionTitle.astro";

const { brand, servicesSection, services } = siteContent;
---

<section id="services" class="relative isolate overflow-hidden bg-ebony py-24">
  <div class="pointer-events-none absolute -left-28 top-1/2 z-0 -translate-y-1/2 sm:-left-20">
    <img
      src={brand.logo}
      alt=""
      aria-hidden="true"
      loading="lazy"
      class="h-[22rem] w-auto max-w-none opacity-[0.06] blur-[1px] sm:h-[30rem] lg:h-[34rem]"
    />
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
    <div data-reveal>
      <SectionTitle
        eyebrow={servicesSection.eyebrow}
        title={servicesSection.title}
        description={servicesSection.description}
        align="center"
      />
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        services.map((service, index) => (
          <article
            data-reveal
            style={`--reveal-delay: ${index * 75}ms;`}
            class="group overflow-hidden bg-[#0f0f0f] rounded-2xl border border-white/10 transition duration-300 hover:-translate-y-1 hover:border-cyan-electric/60 hover:shadow-[0_0_24px_rgba(0,195,227,0.18)]"
          >
            <div class="relative h-52 overflow-hidden">
              <img
                src={service.image}
                alt={service.alt}
                loading="lazy"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
            </div>
            <div class="p-6">
              <h3 class="font-header text-2xl text-white">{service.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-smoke-white/80">{service.description}</p>
              <ul class="mt-5 flex flex-wrap gap-2">
                {service.tags.map((tag) => <li class="rounded-full border border-white/10 px-3 py-1 text-[11px] tracking-wide text-white/70">{tag}</li>)}
              </ul>
              <a
                href={service.href}
                class="mt-6 inline-flex text-xs font-semibold tracking-[0.18em] uppercase text-gold-luxury transition hover:text-cyan-electric"
              >
                Discover Service
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>


