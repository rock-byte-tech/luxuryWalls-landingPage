---
import siteContent from "../data/site-content.json";
import GlowButton from "../components/GlowButton.astro";

const { brand, hero } = siteContent;
---

<section id="home" class="relative isolate flex min-h-screen items-center overflow-hidden bg-[var(--color-ebony)]">
  <div
    class="absolute inset-0 bg-cover bg-center opacity-30"
    style={`background-image: url('${hero.backgroundImage}')`}
  ></div>
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/80 to-[var(--color-ebony)]"></div>
  <div class="absolute -left-24 top-1/3 h-72 w-72 rounded-full bg-[var(--color-cyan-electric)]/20 blur-3xl"></div>
  <div class="absolute -right-20 bottom-1/4 h-64 w-64 rounded-full bg-[var(--color-gold-luxury)]/15 blur-3xl"></div>

  <div class="relative z-10 mx-auto w-full max-w-7xl px-6 pb-20 pt-8 sm:px-8 lg:px-12">
    <header class="mb-20 flex items-center justify-between">
      <a href="#home" class="inline-flex items-center gap-3">
        <img src={brand.logo} alt={`${brand.name} logo`} class="h-16 w-auto object-contain sm:h-20" />
      </a>
      <nav class="hidden items-center gap-8 text-xs font-medium tracking-[0.18em] uppercase text-white/80 md:flex">
        <a href="#services" class="transition hover:text-[var(--color-cyan-electric)]">Services</a>
        <a href="#instagram" class="transition hover:text-[var(--color-cyan-electric)]">Instagram</a>
        <a href="#contact" class="transition hover:text-[var(--color-cyan-electric)]">Contact</a>
      </nav>
    </header>

    <div class="max-w-3xl">
      <p class="mb-5 text-xs font-semibold tracking-[0.3em] uppercase text-[var(--color-gold-luxury)]">
        {hero.eyebrow}
      </p>
      <h1 class="font-[var(--font-header)] text-4xl leading-tight text-white sm:text-5xl md:text-6xl">
        {hero.title}
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-[var(--color-smoke-white)]/90 sm:text-lg">
        {hero.description}
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <GlowButton href={hero.primaryCta.href} label={hero.primaryCta.label} />
        <GlowButton href={hero.secondaryCta.href} label={hero.secondaryCta.label} variant="gold" />
      </div>

      <ul class="mt-10 grid gap-3 text-sm text-[var(--color-smoke-white)]/80 sm:grid-cols-3">
        {
          hero.highlights.map((item) => (
            <li class="rounded-xl border border-white/10 bg-white/5 px-4 py-3 backdrop-blur-sm">{item}</li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
