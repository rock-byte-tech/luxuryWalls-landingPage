---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
const alignmentClasses =
  align === "center" ? "mx-auto max-w-3xl text-center" : "max-w-3xl text-left";
---

<div class={alignmentClasses}>
  <p class="mb-3 text-xs font-semibold tracking-[0.26em] uppercase text-[var(--color-cyan-electric)]">
    {eyebrow}
  </p>
  <h2 class="font-[var(--font-header)] text-3xl leading-tight text-white md:text-5xl">
    {title}
  </h2>
  <p class="mt-4 text-sm leading-relaxed text-[var(--color-smoke-white)]/85 md:text-base">
    {description}
  </p>
</div>
